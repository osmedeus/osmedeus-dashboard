{
  "name": "osmedeus-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbopack",
    "dev:nologin": "NEXT_PUBLIC_DISABLE_LOGIN=true next dev",
    "dev:nologin:turbo": "NEXT_PUBLIC_DISABLE_LOGIN=true next dev --turbopack",
    "dev:mock": "NEXT_PUBLIC_USE_MOCK=true NEXT_PUBLIC_DISABLE_LOGIN=true next dev",
    "dev:mock:turbo": "NEXT_PUBLIC_USE_MOCK=true NEXT_PUBLIC_DISABLE_LOGIN=true next dev --turbopack",
    "dev:api": "BASE_API_URL=http://localhost:8002 next dev",
    "clean:build": "bun scripts/clean-build-artifacts.mjs",
    "build:base": "rm -rf build out && NEXT_EXPORT=true next build",
    "build": "bun run build:base && bun run clean:build",
    "build:static": "bun run build:base && bun run clean:build",
    "start": "next start",
    "start:nologin": "NEXT_PUBLIC_DISABLE_LOGIN=true next start",
    "lint": "eslint ."
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@xyflow/react": "^12.10.2",
    "axios": "^1.14.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.562.0",
    "motion": "^11.18.2",
    "next": "16.1.1",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^15.6.6",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.6.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/dagre": "^0.7.54",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.5",
  "engines": {
    "bun": ">=1.3.0"
  }
}
